    "def find_price_col(price_df):\n",
    "    candidates = []\n",
    "    for c in price_df.columns:\n",
    "        lc = str(c).lower()\n",
    "        if c in ['i', 't', 'm', 'j']:\n",
    "            continue\n",
    "        if 'price' in lc or 'precio' in lc or 'cost' in lc or 'unit' in lc or 'value' in lc:\n",
    "            candidates.append(c)\n",
    "\n",
    "    numeric_cols = [c for c in price_df.columns if pd.api.types.is_numeric_dtype(price_df[c]) and c not in ['i', 't', 'm']]\n",
    "\n",
    "    for c in candidates:\n",
    "        if c in numeric_cols:\n",
    "            return c\n",
    "\n",
    "    if len(numeric_cols) == 1:\n",
    "        return numeric_cols[0]\n",
    "\n",
    "    if 'j' in numeric_cols and len(numeric_cols) > 1:\n",
    "        numeric_cols = [c for c in numeric_cols if c != 'j']\n",
    "\n",
    "    if len(numeric_cols) >= 1:\n",
    "        return numeric_cols[0]\n",
    "\n",
    "    raise ValueError(\"Could not identify price column automatically.\")\n",
    "\n",
    "def nutritional_adequacy_analysis(country_name, x_df, p_df, d_df):\n",
    "    x_use = x_df.copy()\n",
    "    p_use = p_df.copy()\n",
    "    d_use = d_df.copy()\n",
    "\n",
    "    if 'Expenditure' not in x_use.columns:\n",
    "        raise ValueError(f\"{country_name}: expenditure column not found.\")\n",
    "    if 'j' not in x_use.columns:\n",
    "        raise ValueError(f\"{country_name}: food-name column 'j' not found.\")\n",
    "    if 'i' not in x_use.columns:\n",
    "        raise ValueError(f\"{country_name}: household-id column 'i' not found.\")\n",
    "\n",
    "    price_col = find_price_col(p_use)\n",
    "\n",
    "    p_small = p_use[['j', price_col]].drop_duplicates('j').rename(columns={price_col: 'price'})\n",
    "\n",
    "    food = x_use[['i', 'j', 'Expenditure']].merge(p_small, on='j', how='left')\n",
    "\n",
    "    food['price'] = pd.to_numeric(food['price'], errors='coerce')\n",
    "    food['Expenditure'] = pd.to_numeric(food['Expenditure'], errors='coerce')\n",
    "    food = food[(food['price'] > 0) & (food['Expenditure'] >= 0)].copy()\n",
    "\n",
    "    food['quantity'] = food['Expenditure'] / food['price']\n",
    "    food['food_category'] = food['j'].apply(classify_food)\n",
    "\n",
    "    food['kcal_per_unit'] = food['food_category'].map(lambda c: CATEGORY_NUTRIENTS[c]['kcal'])\n",
    "    food['protein_g_per_unit'] = food['food_category'].map(lambda c: CATEGORY_NUTRIENTS[c]['protein_g'])\n",
    "    food['iron_mg_per_unit'] = food['food_category'].map(lambda c: CATEGORY_NUTRIENTS[c]['iron_mg'])\n",
    "\n",
    "    food['kcal_intake'] = food['quantity'] * food['kcal_per_unit']\n",
    "    food['protein_intake'] = food['quantity'] * food['protein_g_per_unit']\n",
    "    food['iron_intake'] = food['quantity'] * food['iron_mg_per_unit']\n",
    "\n",
    "    hh_intake = food.groupby('i')[['kcal_intake', 'protein_intake', 'iron_intake']].sum()\n",
    "\n",
    "    hh_req, matched_demo_cols = build_household_requirements(d_use)\n",
    "\n",
    "    hh = hh_req.join(hh_intake, how='left')\n",
    "    hh[['kcal_intake', 'protein_intake', 'iron_intake']] = hh[['kcal_intake', 'protein_intake', 'iron_intake']].fillna(0)\n",
    "\n",
    "    hh['kcal_ratio'] = np.where(hh['kcal_req'] > 0, hh['kcal_intake'] / hh['kcal_req'], np.nan)\n",
    "    hh['protein_ratio'] = np.where(hh['protein_req'] > 0, hh['protein_intake'] / hh['protein_req'], np.nan)\n",
    "    hh['iron_ratio'] = np.where(hh['iron_req'] > 0, hh['iron_intake'] / hh['iron_req'], np.nan)\n",
    "\n",
    "    hh['meets_kcal'] = hh['kcal_ratio'] >= 1\n",
    "    hh['meets_protein'] = hh['protein_ratio'] >= 1\n",
    "    hh['meets_iron'] = hh['iron_ratio'] >= 1\n",
    "    hh['meets_all_selected_nutrients'] = hh[['meets_kcal', 'meets_protein', 'meets_iron']].all(axis=1)\n",
    "\n",
    "    category_summary = (\n",
    "        food.groupby('food_category')[['kcal_intake', 'protein_intake', 'iron_intake']]\n",
    "        .sum()\n",
    "        .sort_values('kcal_intake', ascending=False)\n",
    "    )\n",
    "\n",
    "    summary = pd.DataFrame({\n",
    "        'Country': [country_name],\n",
    "        'Households': [len(hh)],\n",
    "        'Proportion meeting calorie recommendation': [hh['meets_kcal'].mean()],\n",
    "        'Proportion NOT meeting calorie recommendation': [1 - hh['meets_kcal'].mean()],\n",
    "        'Proportion meeting protein recommendation': [hh['meets_protein'].mean()],\n",
    "        'Proportion NOT meeting protein recommendation': [1 - hh['meets_protein'].mean()],\n",
