    "def demographic_requirement_from_col(col_name):\n",
    "    s = str(col_name).strip().lower()\n",
    "\n",
    "    if 'male' in s:\n",
    "        sex = 'male'\n",
    "    elif 'female' in s:\n",
    "        sex = 'female'\n",
    "    else:\n",
    "        return None\n",
    "\n",
    "    m = re.search(r'(\\d{1,2})\\D+(\\d{1,2})', s)\n",
    "    if not m:\n",
    "        return None\n",
    "\n",
    "    low = int(m.group(1))\n",
    "    high = int(m.group(2))\n",
    "\n",
    "    if high <= 3:\n",
    "        req = {'kcal': 1000, 'protein_g': 13, 'iron_mg': 7}\n",
    "    elif high <= 8:\n",
    "        req = {'kcal': 1400, 'protein_g': 19, 'iron_mg': 10}\n",
    "    elif high <= 13:\n",
    "        req = {'kcal': 1800 if sex == 'male' else 1600, 'protein_g': 34, 'iron_mg': 8}\n",
    "    elif high <= 18:\n",
    "        req = {'kcal': 2200 if sex == 'male' else 1800, 'protein_g': 52 if sex == 'male' else 46, 'iron_mg': 11 if sex == 'male' else 15}\n",
    "    elif high <= 30:\n",
    "        req = {'kcal': 2400 if sex == 'male' else 2000, 'protein_g': 56 if sex == 'male' else 46, 'iron_mg': 8 if sex == 'male' else 18}\n",
    "    elif high <= 50:\n",
    "        req = {'kcal': 2400 if sex == 'male' else 1800, 'protein_g': 56 if sex == 'male' else 46, 'iron_mg': 8 if sex == 'male' else 18}\n",
    "    else:\n",
    "        req = {'kcal': 2200 if sex == 'male' else 1800, 'protein_g': 56, 'iron_mg': 8}\n",
    "\n",
    "    return req\n",
    "\n",
    "def build_household_requirements(d_df):\n",
    "    d2 = d_df.copy()\n",
    "    if 'i' in d2.columns:\n",
    "        d2 = d2.set_index('i')\n",
    "\n",
    "    d2['kcal_req'] = 0.0\n",
    "    d2['protein_req'] = 0.0\n",
    "    d2['iron_req'] = 0.0\n",
    "\n",
    "    matched_demo_cols = []\n",
    "\n",
    "    for col in d2.columns:\n",
    "        req = demographic_requirement_from_col(col)\n",
    "        if req is not None:\n",
    "            matched_demo_cols.append(col)\n",
    "            counts = pd.to_numeric(d2[col], errors='coerce').fillna(0)\n",
    "            d2['kcal_req'] += counts * req['kcal']\n",
    "            d2['protein_req'] += counts * req['protein_g']\n",
    "            d2['iron_req'] += counts * req['iron_mg']\n",
    "\n",
    "    return d2, matched_demo_cols"
   ]
